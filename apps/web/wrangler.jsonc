{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pathstash",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-19",
  "observability": {
    "enabled": true
  },
  "services": [
    {
      "binding": "RELAY",
      "service": "pathstash-relay"
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/*", "!/assets/*"]
  }
}
